# Copy this file to benchmark/.env and fill in your values
# benchmark/.env is gitignored — never commit it

# Required for comparison benchmarks (run_comparison.py)
# Not needed for IntentQL-only benchmarks (run_benchmarks.py)
OPENAI_API_KEY=sk-...

# DB connection — required for comparison benchmarks
# Use a READ-ONLY user
DB_HOST=your-host
DB_PORT=5432
DB_NAME=your-db
DB_USER=your-readonly-user
DB_PASSWORD=your-password
